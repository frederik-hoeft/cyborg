          <y:UML clipContent="true" constraint="" hasDetailsColor="false" omitDetails="false" stereotype="" use3DEffect="false">
            <y:AttributeLabel xml:space="preserve">{
  "configuration": {
    "cyborg.modules.config.map.v1": { ... }
  },
  "environment": { "name": "jobs" },
  "module": {
    "cyborg.modules.sequence.v1": {
      "steps": [
        {
          "module": {
            "cyborg.modules.glob.v1": {
              "name": "job_factory",
              "root": "${job_directory}/",
              "pattern": ".*?\\.jconf$",
              "artifacts": {
                "environment": {
                  "scope": "reference",
                  "name": "jobs"
                }
              }
            }
          }
        },
        {
          "module": {
            "cyborg.modules.foreach.v1": {
              "collection": "job_factory.files",
