{
  "name": "overleaf-backup",
  "hosts": [
    {
      "hostname": "backup1.service.home.arpa",
      "port": 12322,
      "macAddress": "74:46:a0:a1:b6:3c",
      "repository": "/var/backups/borg/nas1.service.home.arpa/overleaf"
    },
    {
      "hostname": "backup2.service.home.arpa",
      "port": 12322,
      "macAddress": "f4:4d:30:45:70:37",
      "repository": "/var/backups/borg/nas1.service.home.arpa/overleaf"
    }
  ],
  "wakeOnLan": {
    "enabled": true,
    "timeout": 60,
    "retries": 3
  },
  "docker": {
    "user": "docker-host",
    "composePath": "/home/docker-host/containers/overleaf/bin/docker-compose",
    "containerGroup": "overleaf"
  },
  "borg": {
    "compression": "zlib",
    "archiveName": "overleaf-{now}",
    "sourcePath": "/home/docker-host/volumes/overleaf",
    "excludePatterns": [
      "*/mongo/diagnostic.data/*",
      "*/sharelatex/tmp/*",
      "*/sharelatex/data/cache/*",
      "*/sharelatex/data/compiles/*",
      "*/sharelatex/data/output/*"
    ],
    "keepDaily": 30,
    "keepWeekly": 12,
    "keepMonthly": 12
  },
  "passphrase": "REPLACE_WITH_ACTUAL_PASSPHRASE"
}
