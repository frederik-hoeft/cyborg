{
  "environment": {
    "name": "global",
    "scope": "global"
  },
  "configuration": {
    "cyborg.modules.config.map.v1": {
      "entries": [
        {
          "key": "job_name",
          "string": "daily"
        }
      ]
    }
  },
  "module": {
    "cyborg.modules.sequence.v1": {
      "steps": [
        {
          "environment": {
            "name": "wol",
            "scope": "inherit_parent"
          },
          "configuration": {
            "cyborg.modules.config.map.v1": {
              "entries": [
                {
                  "key": "log_level",
                  "string": "warning"
                },
                {
                  "key": "throw_on_error",
                  "bool": true
                },
                {
                  "key": "max_retries",
                  "int": 3
                },
                {
                  "key": "foo",
                  "string": "yaaay, dynamic types!"
                },
                {
                  "key": "indirection_via_environment_inheritance",
                  "string": "${job_name}"
                }
              ]
            }
          },
          "module": {
            "cyborg.modules.subprocess.v1": {
              "output": {
                "namespace": "list_files",
                "read_stdout": true,
                "read_stderr": true
              },
              "command": {
                "executable": "ls",
                "arguments": [ "-la" ]
              }
            }
          }
        },
        {
          "environment": {
            "name": "wol",
            "scope": "reference"
          },
          "module": {
            "cyborg.modules.subprocess.v1": {
              "command": {
                "executable": "cat",
                "arguments": [ "config.json" ]
              }
            }
          }
        }
      ]
    }
  }
}
