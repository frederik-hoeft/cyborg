{
  "environment": { "scope": "global" },
  "configuration": {
    "cyborg.modules.config.map.v1": {
      "entries": [
        { "key": "cyborg_config_root", "string": "." },
        { "key": "cyborg_job_root", "string": "${cyborg_config_root}/jobs" },
        { "key": "cyborg_log_file", "string": "./cyborg.log" },
        {
          "key": "backup_hosts",
          "collection<cyborg.types.borg.remote.v1>": [
            {
              "hostname": "backup1.service.local",
              "port": 22,
              "wake_on_lan_mac": "aa:bb:cc:dd:ee:ff",
              "borg_rsh": "/usr/bin/sshpass -f/root/.ssh/pass -P assphrase /usr/bin/ssh",
              "borg_repo_root": "/var/backups/borg/my-client.service.local"
            },
            {
              "hostname": "backup2.service.local",
              "port": 22,
              "wake_on_lan_mac": "00:11:22:33:44:55",
              "borg_rsh": "/usr/bin/sshpass -f/root/.ssh/pass -P assphrase /usr/bin/ssh",
              "borg_repo_root": "/var/backups/borg/my-client.service.local"
            }
          ]
        },
        {
          "key": "allowed_run_as_users",
          "collection<string>": [ "docker", "backup" ]
        }
      ]
    }
  },
  "module": {
    "cyborg.modules.sequence.v1": {
      "steps": [
        {
          "module": {
            "cyborg.modules.environment.defs.v1": {
              "environments": [
                { "name": "wol" }
              ]
            }
          }
        },
        {
          "module": {
            "cyborg.modules.foreach.v1": {
              "collection": "backup_hosts",
              "item_variable": "host",
              "body": {
                "configuration": {
                  "cyborg.modules.config.map.v1": {
                    "entries": [
                      // need to inject the port into the module via override since port is an integer
                      {
                        "key": "@my_wol.liveness_probe_port",
                        "string": "${host.port}"
                      }
                    ]
                  }
                },
                "module": {
                  "cyborg.modules.network.wol.v1": {
                    "name": "my_wol",
                    "executable": "C:\\Windows\\system32\\calc.exe",
                    "target_host": "${host.hostname}",
                    "mac_address": "${host.wake_on_lan_mac}",
                    "artifacts": {
                      "namespace": "${@}.${host.hostname}",
                      "environment": {
                        "scope": "reference",
                        "name": "wol"
                      }
                    }
                  }
                }
              }
            }
          }
        },
        {
          "environment": {
            "scope": "inherit_parent",
            "name": "jobs"
          },
          "module": {
            "cyborg.modules.sequence.v1": {
              "steps": [
                {
                  "module": {
                    "cyborg.modules.glob.v1": {
                      "name": "job_factory",
                      "root": "${cyborg_job_root}/${template}/",
                      "pattern": ".*?\\.jconf$",
                      "artifacts": {
                        "environment": {
                          "scope": "reference",
                          "name": "jobs"
                        }
                      }
                    }
                  }
                },
                {
                  "module": {
                    "cyborg.modules.foreach.v1": {
                      "collection": "job_factory.files",
                      "item_variable": "job",
                      "body": {
                        "module": {
                          "cyborg.modules.external.v1": {
                            "path": "${job}"
                          }
                        }
                      }
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "environment": { "scope": "reference", "name": "wol" },
          "module": {
            "cyborg.modules.foreach.v1": {
              "collection": "backup_hosts",
              "item_variable": "host",
              "body": {
                "module": {
                  "cyborg.modules.if.v1": {
                    "condition": {
                      "cyborg.modules.if.condition.is_true.v1": {
                        "variable": "my_wol.${host.hostname}.woke_up"
                      }
                    },
                    "then": {
                      "module": {
                        "cyborg.modules.network.ssh_shutdown.v1": {
                          "hostname": "${host.hostname}",
                          "username": "root",
                          "ssh_pass": {
                            "file_path": "/root/.ssh/pass",
                            "match_prompt": "assphrase"
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}